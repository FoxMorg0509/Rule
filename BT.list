# DOMAIN: 匹配特定的域名
# DOMAIN-SUFFIX: 匹配以特定后缀结尾的域名。
# DOMAIN-KEYWORD: 匹配包含特定关键字的域名。
# IP-CIDR: 匹配特定的 IP 地址或 CIDR 范围。
# GEOIP: 根据地理位置匹配 IP 地址。
# MATCH: 匹配所有未被其他规则匹配的流量。

# BitTorrent 默认端口
DST-PORT,6881
# BT 常见端口范围
DST-PORT,6882-6999
# Transmission 默认端口
DST-PORT,51413

DOMAIN-SUFFIX,bt-tracker.com
DOMAIN-SUFFIX,announce.torrent
DOMAIN-SUFFIX,tracker.opentrackr.org

# 屏蔽所有含 "tracker" 的域名
DOMAIN-KEYWORD,tracker

